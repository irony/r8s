{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "lib": ["ES2022"],
    "jsx": "react-jsx",
    "jsxImportSource": "@r8s/core",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "paths": {
      "@r8s/core": ["./packages/core/src/index.ts"],
      "@r8s/core/defaults": ["./packages/core/src/defaults.ts"],
      "@r8s/core/jsx-runtime": ["./packages/core/src/jsx-runtime.ts"],
      "@r8s/core/jsx-dev-runtime": ["./packages/core/src/jsx-runtime.ts"],
      "@r8s/k8s-types": ["./packages/k8s-types/src/index.ts"],
      "@r8s/recipes": ["./packages/recipes/src/index.ts"],
      "@r8s/cert-manager": ["./packages/cert-manager/src/index.ts"],
      "@r8s/openbao": ["./packages/openbao/src/index.ts"],
      "@r8s/keycloak": ["./packages/keycloak/src/index.ts"],
      "@r8s/external-dns": ["./packages/external-dns/src/index.ts"],
      "@r8s/r8s-controller": ["./packages/r8s-controller/src/controller.ts"],
      "@r8s/redis": ["./packages/redis/src/index.ts"],
      "@r8s/envoy": ["./packages/envoy/src/index.ts"],
      "@r8s/prometheus": ["./packages/prometheus/src/index.ts"],
      "@r8s/clickhouse": ["./packages/clickhouse/src/index.ts"],
      "@r8s/logging-operator": ["./packages/logging-operator/src/index.ts"],
      "@r8s/loki": ["./packages/loki/src/index.ts"]
    }
  },
  "files": [],
  "references": [
    { "path": "./packages/k8s-types" },
    { "path": "./packages/core" },
    { "path": "./packages/recipes" },
    { "path": "./packages/cert-manager" },
    { "path": "./packages/openbao" },
    { "path": "./packages/keycloak" },
    { "path": "./packages/external-dns" },
    { "path": "./packages/r8s-controller" },
    { "path": "./packages/redis" },
    { "path": "./packages/envoy" },
    { "path": "./packages/prometheus" },
    { "path": "./packages/clickhouse" },
    { "path": "./packages/logging-operator" },
    { "path": "./packages/loki" },
    { "path": "./packages/cli" }
  ]
}
